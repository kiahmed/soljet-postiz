# === Arboryx.ai parent tier config ===
# Style mirrors arboryx-admin/arboryx_admin_backend.config (shell-style key=value).
# Sourceable from bash; parsed by src/lib/config_loader.py for Python tooling.

TIER_ID="arboryx"
TIER_NAME="Arboryx.ai"
TIER_PARENT=""                           # parent tier has no parent
CONTEXT_FILE="context.md"
HANDLES_FILE="handles.yaml"

# === Live data sources ============================================
# Firestore findings — six thematic sectors, daily ingestion from market scouts
# in marketresearch-agents (GCP). Auth via gcloud ADC.
DATA_SOURCE_1_TYPE="firestore"
DATA_SOURCE_1_GCP_PROJECT="marketresearch-agents"
DATA_SOURCE_1_COLLECTION="findings"
DATA_SOURCE_1_AUTH="gcloud_adc"

# Six sectors (matches arboryx.ai/values.yaml scouts).
# Used for filtering, sector-level digests, and routing posts.
SECTORS="Robotics,Crypto,AI Stack,Space & Defense,Power & Energy,Strategic Minerals"

# === Channels (Postiz integration IDs) ============================
CHANNEL_X_PRIMARY="${POSTIZ_INTEGRATION_ID_X_ARBORYX}"   # @arboryx_ai — id resolved from .env
# CHANNEL_X_BUSINESS removed 2026-05-02 — SolutionJet integration was
# soft-deleted in Postiz (Integration.deletedAt 2026-04-24). Re-add this
# line with the new integration ID after reconnecting in Postiz UI when
# the broader cross-product channel strategy is built out.

# LinkedIn — Arboryx Company Page connected 2026-05-19 via CM-API-approved dev app.
# Runtime gate is LINKEDIN_ENABLED in repo-root .env.
CHANNEL_LINKEDIN="${POSTIZ_INTEGRATION_ID_LINKEDIN}"   # id resolved from .env

# === Postiz routing ==============================================
POSTIZ_CUSTOMER_ID="${POSTIZ_CUSTOMER_ID_ARBORYX}"   # Customer "Arboryx.ai" — id resolved from .env

# === Cadence hints ===============================================
# Used by the dispatcher/scheduler. The composer respects these when
# auto-scheduling.
POSTING_CADENCE_DAILY="true"
POSTING_TIMEZONE="America/New_York"

# === Posting purpose ============================================
# What this tier exists to publish. Used as a system-prompt anchor for drafts.
POSTING_PURPOSE="Daily market intelligence from six thematic sectors. Surface high-signal catalysts (launches, M&A, funding, breakthroughs), align them to the arbor metaphor, and route to the right voice. Parent-tier posts are sector-spanning digests and product narrative; branch-tier posts go deep on a single sector."

# === Deep-link funnel ===========================================
# Every parent-tier finding-anchored post embeds this URL, formatted with
# the finding's sector / entry_id / date. X auto-renders a clickable link
# card from the destination's og:image — drives traffic by design.
PARENT_URL_TEMPLATE="https://arboryx.ai/new_growth.html?sector={sector}&entry={entry_id}&date={date}"

# When true (default), the imagery ladder skips attaching its own image
# whenever a deep link is in the post text — letting X render the link card
# and keeping the click target on the URL. Flip to false on tiers whose
# destination doesn't yet expose a per-entry og:image and you'd rather
# attach our generated graph/branded card.
LET_X_RENDER_LINK_CARD="true"

# === Branch enable flags =======================================
# Mirrors the SECTOR_*_ENABLED pattern in arboryx-admin/frontend/arboryx_frontend.config.
# Dispatcher (`bin/_common.integration_ids_for`) refuses to post to a branch
# tier whose flag is false. Lets us scaffold all six branches and turn each
# on as its frontend matures. Branch short-name is the `arboryx.<name>`
# suffix uppercased: arboryx.robotics → BRANCH_ROBOTICS_ENABLED.
BRANCH_ROBOTICS_ENABLED="true"
BRANCH_CRYPTO_ENABLED="false"
BRANCH_AI_STACK_ENABLED="false"
BRANCH_SPACE_DEFENSE_ENABLED="false"
BRANCH_POWER_ENERGY_ENABLED="false"
BRANCH_STRATEGIC_MINERALS_ENABLED="false"
