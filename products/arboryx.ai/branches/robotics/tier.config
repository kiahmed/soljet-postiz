# === Arboryx.ai > Robotics branch tier ===
# Inherits parent voice + base channels. Adds tier-2 KG (catalysts +
# entities + relationships) and filters parent Firestore source to
# Robotics-category findings only.

TIER_ID="arboryx.robotics"
TIER_NAME="Robotics (branch)"
TIER_PARENT="arboryx"
CONTEXT_FILE="context.md"

# === Live data sources ============================================
# Curated card output of the KG pipeline — primary source for branch posts.
# LIVE cards from Firestore — the same source the robotics site reads, so post
# text stays in lock-step with the live per-card pages / og:images (no stale
# snapshot). Each card carries entities + relationships in structured form, so
# the imagery layer can render an entity-impact graph WITHOUT an LLM call.
# (Replaced the static ../catalyst-knowledge-graph/frontend/cards.json, which
# was a frozen April export — 15 cards vs 200 live.)
DATA_SOURCE_1_TYPE="firestore_cards"
DATA_SOURCE_1_GCP_PROJECT="marketresearch-agents"
DATA_SOURCE_1_COLLECTION="CKG-Robotics/catalysts/items"
DATA_SOURCE_1_AUTH="gcloud_adc"

# Tier-2 KG raw store — kept for richer queries that don't fit cards.json.
# (data/arbor.duckdb is a stale duplicate; ignore it.)
DATA_SOURCE_2_TYPE="duckdb"
DATA_SOURCE_2_PATH="../../../../../catalyst-knowledge-graph/data/robotics.duckdb"

# Inherits parent Firestore source, filtered to Robotics findings only.
DATA_SOURCE_3_TYPE="firestore_inherited"
DATA_SOURCE_3_INHERIT_FROM="arboryx"
DATA_SOURCE_3_FILTER_CATEGORY="Robotics"

# === Channels =====================================================
# Inherits parent's X channels. When a dedicated Robotics handle exists
# (e.g., via robotics.arboryx.ai's own LinkedIn Showcase), add IDs here.
CHANNELS_INHERIT_FROM="arboryx"
DEDICATED_CHANNELS=""

# === Postiz routing ==============================================
POSTIZ_CUSTOMER_ID="${POSTIZ_CUSTOMER_ID_ROBOTICS}"   # Customer "Robotics" — id resolved from .env

# === Branch metadata ============================================
PUBLISH_SUBDOMAIN="robotics.arboryx.ai"
KG_REPO_PATH="../../../../../catalyst-knowledge-graph"

# === Deep-link funnel =========================================
# Card-anchored posts embed this URL in the text. Substituted with the
# card's `card_id`. Path-based `/card/<id>` route — the frontend server-renders
# per-card og:image + og:title there, so X/LinkedIn render a per-card link card.
# (The `?card=<id>` query route only serves generic/static og tags to crawlers.)
KG_CARD_URL_TEMPLATE="https://robotics.arboryx.ai/card/{card_id}"

# === Per-channel imagery policy ================================
# X renders a full-width link card from the deep link in the text (og:image),
# so attach NO media there. LinkedIn demoted organic link posts to a tiny thumb,
# so attach the card PNG natively instead (downloaded from the /card page's
# og:image URL). Values: link_card | attach. Absent channel → legacy behavior.
IMAGERY_POLICY_X="link_card"
IMAGERY_POLICY_LINKEDIN="attach"

# === Post text + entity tagging =================================
# Which KG copy to post (identical across every channel): share | headline.
POST_TEXT_SOURCE="share"
# $TICKER cashtags for subject entities that carry a stock ticker (public
# companies only — never a $ before private-company names).
CASHTAGS_ENABLED="false"
# @handle mentions for subject entities. OFF until the KG resolver ships verified
# handles (embedded on the card entity, or served by HANDLE_ENDPOINT_URL below).
HANDLE_INJECTION="false"
# How to tag an entity that has BOTH a handle and a ticker:
#   prefer_handle (default) | handle_only | cashtag_only | both
ENTITY_TAG_MODE="prefer_handle"
# Max entity tags appended per post.
MAX_ENTITY_TAGS="2"
# Handle source when HANDLE_INJECTION=true and handles are NOT embedded on the
# card: a resolver endpoint (KG Cloud Function). Empty = use card-embedded
# handles + the local products/_shared/handles.json override only.
HANDLE_ENDPOINT_URL=""

# Inherits parent's LET_PLATFORM_RENDER_LINK_CARD by default (used only for
# channels without an explicit IMAGERY_POLICY_* above).
# LET_PLATFORM_RENDER_LINK_CARD="true"

# === Posting purpose ============================================
POSTING_PURPOSE="Domain-deep posts for the Robotics branch (physical AI, embodied robotics, manipulation, locomotion, sim-to-real). Anchor every post to a catalyst from the KG: name the company/lab, tie it to entities and relationships from the graph, and frame in arbor language (catalysts as buds, fruits as deployed systems). Audience is technical: founders, researchers, operators."
