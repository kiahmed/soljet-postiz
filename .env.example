# === Postiz Deployment Config ===
POSTIZ_PORT=4007
POSTIZ_IMAGE=ghcr.io/gitroomhq/postiz-app:latest

# === URLs (adjust for your host)
# Using Cloudflare tunnel for HTTPS dev access (so X OAuth callbacks work).
# For pure localhost, revert to http://localhost:4007.
MAIN_URL=https://dev.arboryx.ai
FRONTEND_URL=https://dev.arboryx.ai
NEXT_PUBLIC_BACKEND_URL=https://dev.arboryx.ai/api
BACKEND_INTERNAL_URL=http://localhost:3000

# === Security
JWT_SECRET=replace-with-a-long-random-string

# === Database
POSTGRES_USER=postiz-user
POSTGRES_PASSWORD=postiz-password
POSTGRES_DB=postiz-db-local
DATABASE_URL=postgresql://postiz-user:postiz-password@postiz-postgres:5432/postiz-db-local

# === Redis
REDIS_URL=redis://postiz-redis:6379

# === Storage (local)
STORAGE_PROVIDER=local
UPLOAD_DIRECTORY=/uploads
NEXT_PUBLIC_UPLOAD_DIRECTORY=/uploads

# === Social Media APIs (fill in to enable)
# X (Twitter)
X_API_KEY=your-x-api-key
X_API_SECRET=your-x-api-secret

# LinkedIn — gated. Fill IDs when dev app is created; flip LINKEDIN_ENABLED=true
# once Postiz UI has the channel connected. While disabled, the draft pipeline
# skips LinkedIn integration IDs in tier.config (CHANNEL_LINKEDIN).
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_ENABLED=false
LINKEDIN_BACKFILL_DAYS=7

# Reddit
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=

# === Temporal
TEMPORAL_ADDRESS=temporal:7233

# === Misc
IS_GENERAL=true
DISABLE_REGISTRATION=false
OPENAI_API_KEY=sk-your-openai-api-key
API_LIMIT=30
NX_ADD_PLUGINS=false
FEE_AMOUNT=0.05

# === Cloudflare Tunnel (dev HTTPS via dev.arboryx.ai) ===
# Routes dev.arboryx.ai -> http://postiz:5000 via cloudflared container.
# To disable: comment out the cloudflared service in docker-compose.yaml AND
# revert MAIN_URL/FRONTEND_URL/NEXT_PUBLIC_BACKEND_URL back to http://localhost:4007.
CF_TUNNEL_TOKEN=your-cloudflare-tunnel-token

# === Azure Cloud Deployment (used only by azure-*.sh scripts) ===
# Master switch — azure-deploy.sh refuses to run unless this is true
AZURE_ENABLED=false

# Subscription / tenant (taken from current `az account show`; override if needed)
AZURE_SUBSCRIPTION_ID=your-azure-subscription-id
AZURE_TENANT_ID=your-azure-tenant-id

# Where to create resources — script will create the RG if it doesn't exist
AZURE_RESOURCE_GROUP=rg-solutionjet-postiz
AZURE_LOCATION=eastus

# VM sizing — Postiz + Postgres + Redis + Temporal + Elasticsearch needs ~6 GB RAM
# B2ms = 2 vCPU / 8 GB (~$30/mo), B4ms = 4 vCPU / 16 GB (~$60/mo, recommended)
AZURE_VM_NAME=postiz-vm
AZURE_VM_SIZE=Standard_B4ms
AZURE_VM_IMAGE=Ubuntu2404
AZURE_VM_ADMIN_USER=azureuser
AZURE_VM_OS_DISK_GB=64

# SSH public key used to log into the VM (must exist before deploy)
AZURE_SSH_KEY_PATH=~/.ssh/id_rsa.pub

# Optional DNS label — if set, VM gets <label>.<region>.cloudapp.azure.com
# Leave empty to use raw public IP
AZURE_DNS_LABEL=arboryx-postiz

# NSG — comma-separated TCP ports to open to the public internet
# 22 = SSH, 80/443 = future TLS reverse proxy, 4007 = Postiz UI, 8080 = Temporal UI
# Tighten this for production (e.g., remove 8080, restrict 22 to your IP)
AZURE_OPEN_PORTS=22,80,443,4007,8080

# Optional: restrict SSH to a single source CIDR (e.g., your office IP). Empty = anywhere
AZURE_SSH_SOURCE_CIDR=

# Remote install path on the VM
AZURE_REMOTE_APP_DIR=/opt/postiz

# === Live data sources (used by bin/list-recent.py + bin/draft.py) ===
# GCP project hosting the `findings` Firestore collection. Auth = gcloud ADC.
# Run `gcloud auth application-default login` once on this machine.
GCP_PROJECT=marketresearch-agents

# === Postiz public API (used by bin/draft.py to push drafts) ===
# Per-org key. Pull from the Organization.apiKey column in the Postiz DB,
# or generate via Postiz UI → Settings → API.
POSTIZ_API_KEY=
POSTIZ_API_URL=https://dev.arboryx.ai

# === Postiz routing ids ===
# Referenced via ${...} from products/**/tier.config and handles.yaml so the
# live ids stay out of git. Pull from the Postiz DB (Customer / Integration
# tables) or the Postiz UI. Leave blank to disable that channel/customer.
POSTIZ_CUSTOMER_ID_ARBORYX=
POSTIZ_CUSTOMER_ID_ROBOTICS=
POSTIZ_INTEGRATION_ID_X_ARBORYX=
POSTIZ_INTEGRATION_ID_LINKEDIN=
X_ACCOUNT_ID_ARBORYX=

# === OpenAI rewrite model (key is OPENAI_API_KEY above) ===
OPENAI_MODEL=gpt-4o-mini

# === Daily scheduler volume (optional) ==========================
# How many cards the daily cron publishes per run, spacing, and which tier.
# Set these instead of editing ops/scheduler/run-daily.sh.
# X bills ~$0.20 per post, so DAILY_POST_COUNT is a cost dial:
#   1/day ≈ $6/mo    3/day ≈ $18/mo    5/day ≈ $30/mo
# DAILY_POST_TIER: omit for robotics-only (default); set EMPTY for all tiers.
DAILY_POST_COUNT=1
DAILY_POST_DELAY=90
DAILY_POST_TIER=arboryx.robotics
